# Xcode
# Ignore everything inside xcodeproj/xcworkspace directories, then
# selectively un-ignore the files that should be committed.
# IMPORTANT: using dir/* (not dir/) so negations can reach inside.
*.xcodeproj/*
!*.xcodeproj/project.pbxproj
!*.xcodeproj/project.xcworkspace/
*.xcodeproj/project.xcworkspace/*
!*.xcodeproj/project.xcworkspace/contents.xcworkspacedata
*.xcworkspace/*
!*.xcworkspace/contents.xcworkspacedata
xcuserdata/
*.xcuserstate
DerivedData/
.build/
*.o
*.d
*.swp
*.lock
*.moved-aside
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3

# Swift Package Manager
.swiftpm/
.build/
Packages/

# CocoaPods
Pods/
Podfile.lock

# Secrets (GlycoTrack.xcconfig is committed as a stub; put real values in GlycoTrack.local.xcconfig)
GlycoTrack/Config/GlycoTrack.local.xcconfig
Secrets.swift
.env

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
.vscode/
